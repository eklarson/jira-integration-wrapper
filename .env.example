# Jira Integration Configuration
# Copy this file to .env and fill in your values.
# Never commit this file!

JIRA_SERVER=https://yourcompany.atlassian.net

# --- Authentication (choose ONE of the two blocks below) ---

# Jira Cloud (most common)
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=your_api_token_from_id.atlassian.com

# Jira Server / Data Center (Personal Access Token)
# JIRA_TOKEN_AUTH=your_pat_token_here

# --- Optional settings ---

# Verify SSL certificates (default: true, set to false only for testing)
JIRA_VERIFY_SSL=true

# HTTP proxies (two equivalent ways)

# Option A: JSON object (preferred when you have multiple proxy settings)
# JIRA_PROXIES={"http": "http://proxy:8080", "https": "http://proxy:8080"}

# Option B: separate variables
# JIRA_HTTP_PROXY=http://proxy:8080
# JIRA_HTTPS_PROXY=http://proxy:8080